<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodSnap.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Dynamic Font Size Resources -->
            <x:Double x:Key="SmallFontSize">12</x:Double>
            <x:Double x:Key="NormalFontSize">14</x:Double>
            <x:Double x:Key="MediumFontSize">16</x:Double>
            <x:Double x:Key="LargeFontSize">18</x:Double>
            <x:Double x:Key="TitleFontSize">22</x:Double>
            <x:Double x:Key="ButtonFontSize">16</x:Double>
            <x:Double x:Key="ButtonHeight">50</x:Double>

            <!-- Global Button Style -->
            <Style TargetType="Button" ApplyToDerivedTypes="True">
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSize}" />
                <Setter Property="MinimumHeightRequest" Value="{StaticResource ButtonHeight}" />
                <Setter Property="HeightRequest" Value="-1" />
                <Setter Property="Padding" Value="10,12" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Disabled">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="LightGray" />
                                    <Setter Property="TextColor" Value="DarkGray" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <!-- Global Label Style -->
            <Style TargetType="Label" ApplyToDerivedTypes="True">
                <Setter Property="FontSize" Value="{StaticResource NormalFontSize}" />
            </Style>

            <!-- Global Frame Style -->
            <Style TargetType="Frame" ApplyToDerivedTypes="True">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="HasShadow" Value="False" />
            </Style>

            <!-- Global Entry Style -->
            <Style TargetType="Entry" ApplyToDerivedTypes="True">
                <Setter Property="FontSize" Value="{StaticResource NormalFontSize}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>