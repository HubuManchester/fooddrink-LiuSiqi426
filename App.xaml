<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodSnap.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Font Size Resources (will be updated dynamically) -->
            <x:Double x:Key="NormalFontSize">14</x:Double>
            <x:Double x:Key="LargeFontSize">18</x:Double>
            <x:Double x:Key="TitleFontSize">22</x:Double>
            <x:Double x:Key="ButtonFontSize">16</x:Double>
            <x:Double x:Key="SmallFontSize">12</x:Double>

            <!-- Global Button Style -->
            <Style TargetType="Button" ApplyToDerivedTypes="True">
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSize}" />
                <Setter Property="MinimumHeightRequest" Value="50" />
                <Setter Property="HeightRequest" Value="-1" />
                <Setter Property="Padding" Value="10,12" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <!-- Global Label Style -->
            <Style TargetType="Label" ApplyToDerivedTypes="True">
                <Setter Property="FontSize" Value="{StaticResource NormalFontSize}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>