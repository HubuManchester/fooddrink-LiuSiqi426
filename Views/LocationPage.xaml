<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodSnap.Views.LocationPage"
             Title="Nearby Places">

    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="15">

            <Label Text="📍 Find healthy food near you" 
                   FontSize="{DynamicResource TitleFontSize}" 
                   HorizontalOptions="Center" FontAttributes="Bold" 
                   TextColor="#555555" Margin="0,0,0,10"/>

            <!-- Buttons -->
            <Button x:Name="getLocationButton" Text="📍  Show My Location" Clicked="OnGetLocationClicked" 
                    BackgroundColor="#D4B0B5" TextColor="White" CornerRadius="10" HeightRequest="50" Margin="10,5"/>

            <Button x:Name="findPlacesButton" Text="🍽️  Find Nearby Restaurants" Clicked="OnFindNearbyClicked" 
                    BackgroundColor="#9CAF88" TextColor="White" CornerRadius="10" HeightRequest="50" Margin="10,5" IsEnabled="False"/>

            <Button x:Name="speakLocationButton" Text="🔊  Speak Location Info" Clicked="OnSpeakLocationClicked" 
                    BackgroundColor="#C49799" TextColor="White" CornerRadius="10" HeightRequest="50" Margin="10,5" IsEnabled="False"/>

            <Button x:Name="stopSpeakButton" Text="⏹️  Stop Speaking" Clicked="OnStopSpeakingClicked" 
                    BackgroundColor="#BC8E87" TextColor="White" CornerRadius="10" HeightRequest="50" Margin="10,5"/>

            <!-- Location display area -->
            <Frame BorderColor="LightGray" CornerRadius="10" Padding="10" Margin="0,15,0,0" BackgroundColor="White">
                <VerticalStackLayout>
                    <Label Text="📍 Your Location" FontAttributes="Bold" 
                           FontSize="{DynamicResource MediumFontSize}" TextColor="#555555"/>
                    <Label x:Name="locationStatusLabel" Text="Tap 📍 button to get location" 
                           FontSize="{DynamicResource SmallFontSize}" TextColor="Gray" LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Nearby restaurants display area -->
            <Frame BorderColor="LightGray" CornerRadius="10" Padding="10" BackgroundColor="White">
                <VerticalStackLayout>
                    <Label Text="🍽️ Nearby Restaurants" FontAttributes="Bold" 
                           FontSize="{DynamicResource MediumFontSize}" TextColor="#555555"/>
                    <Label x:Name="placesListLabel" Text="Get location first, then tap 🍽️" 
                           FontSize="{DynamicResource SmallFontSize}" TextColor="Gray" LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>