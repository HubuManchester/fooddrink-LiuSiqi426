<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodSnap.Views.HomePage"
             Title="Home"
             x:Name="HomePageRoot">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="5" Padding="15">
            <Label Text="FoodSnap" 
                   FontSize="{DynamicResource TitleFontSize}" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"
                   TextColor="#D4B0B5"/>
            <Label Text="Your personal nutrition assistant" 
                   FontSize="{DynamicResource MediumFontSize}" 
                   HorizontalOptions="Center" 
                   TextColor="#555555"/>
        </VerticalStackLayout>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="15" Padding="15">

                <!-- Search Bar -->
                <Frame CornerRadius="10" Padding="5" BackgroundColor="White" BorderColor="#E0E0E0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5">
                        <Entry x:Name="searchEntry" 
                               Placeholder="Search for food or recipe..." 
                               FontSize="{DynamicResource NormalFontSize}"
                               TextChanged="OnSearchTextChanged"
                               BackgroundColor="Transparent"/>
                        <Button x:Name="searchButton" 
                                Grid.Column="1" 
                                Text="🔍" 
                                Clicked="OnSearchClicked"
                                WidthRequest="50" 
                                HeightRequest="44"
                                CornerRadius="8"
                                BackgroundColor="#D4B0B5"/>
                    </Grid>
                </Frame>

                <!-- Search Results -->
                <StackLayout x:Name="searchResultsLayout" IsVisible="False">
                    <Label Text="Search Results" 
                           FontSize="{DynamicResource MediumFontSize}" 
                           FontAttributes="Bold" TextColor="#555555"/>
                    <CollectionView x:Name="searchResultsView" 
                                    SelectionMode="Single" 
                                    SelectionChanged="OnSearchResultSelected"/>
                </StackLayout>

                <!-- Today's Recommendations -->
                <StackLayout x:Name="recommendationsLayout">
                    <Label Text="Today's Recommendations" 
                           FontSize="{DynamicResource MediumFontSize}" 
                           FontAttributes="Bold" TextColor="#555555"/>
                    <CollectionView x:Name="recommendationsView" 
                                    SelectionMode="Single" 
                                    SelectionChanged="OnRecommendationSelected">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2"/>
                        </CollectionView.ItemsLayout>
                    </CollectionView>
                </StackLayout>

                <!-- Popular Foods -->
                <StackLayout Margin="0,10,0,0">
                    <Label Text="Popular Foods" 
                           FontSize="{DynamicResource MediumFontSize}" 
                           FontAttributes="Bold" TextColor="#555555"/>
                    <CollectionView x:Name="popularFoodsView" 
                                    SelectionMode="Single" 
                                    SelectionChanged="OnPopularFoodSelected"/>
                </StackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Start Scanning Button -->
        <Button Grid.Row="2" 
                Text="Start Scanning"
                Clicked="OnStartScanningClicked"
                BackgroundColor="#D4B0B5"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"
                Margin="30,0,30,15"
                FontSize="{DynamicResource ButtonFontSize}"/>

    </Grid>
</ContentPage>