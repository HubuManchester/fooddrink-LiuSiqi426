<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodSnap.Views.ShakePage"
             Title="Shake for Recipe">

    <VerticalStackLayout Spacing="15" Padding="15" VerticalOptions="Center">

        <Label Text="🫨" FontSize="70" HorizontalOptions="Center"/>

        <Label x:Name="instructionLabel" Text="Shake your phone to get a random recipe!" 
               FontSize="{DynamicResource MediumFontSize}" HorizontalOptions="Center" FontAttributes="Bold" TextColor="#D4B0B5"/>

        <Frame BorderColor="#E0E0E0" CornerRadius="15" Padding="15" BackgroundColor="White" HasShadow="True">
            <VerticalStackLayout Spacing="8">
                <Label x:Name="recipeNameLabel" Text="???" 
                       FontSize="{DynamicResource TitleFontSize}" HorizontalOptions="Center" 
                       FontAttributes="Bold" TextColor="#C49799"/>
                <Label x:Name="ingredientsLabel" Text="Shake to see ingredients" 
                       FontSize="{DynamicResource NormalFontSize}" TextColor="#9E9E9E"/>
                <Label x:Name="instructionsLabel" Text="Shake to see instructions" 
                       FontSize="{DynamicResource NormalFontSize}" TextColor="#9E9E9E"/>
            </VerticalStackLayout>
        </Frame>

        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
            <Button x:Name="speakButton" Text="🔊" Clicked="OnSpeakClicked" 
                    BackgroundColor="#C49799" TextColor="White" CornerRadius="25" WidthRequest="55" HeightRequest="55" FontSize="22" IsEnabled="False"/>
            <Button x:Name="stopSpeakButton" Text="⏹️" Clicked="OnStopSpeakingClicked" 
                    BackgroundColor="#BC8E87" TextColor="White" CornerRadius="25" WidthRequest="55" HeightRequest="55" FontSize="22"/>
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>