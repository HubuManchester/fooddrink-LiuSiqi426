<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodSnap.Views.Controls.LoadingOverlay"
             x:Name="this">
    <Grid>
        <BoxView Color="Black" Opacity="0.6"/>
        <VerticalStackLayout
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="15">
            <ActivityIndicator
                IsRunning="{Binding Source={x:Reference this}, Path=IsVisible}"
                Color="{StaticResource PrimaryColor}"
                Scale="1.5"/>
            <Label
                x:Name="loadingTextLabel"
                Text="Loading..."
                TextColor="White"
                FontSize="16"
                HorizontalOptions="Center"/>
            <ProgressBar
                x:Name="progressBar"
                IsVisible="False"
                Progress="0"
                ProgressColor="{StaticResource PrimaryColor}"
                WidthRequest="200"/>
        </VerticalStackLayout>
    </Grid>
</ContentView>